# Copy to .env (gitignored) and fill in. `docker compose` reads .env automatically.

# Path to the project you want the agent to work on (mounted at /workspace,
# and read-only at /project for the ingest worker). Use an absolute path.
PROJECT_DIR=/absolute/path/to/your/project

# Which role config the agent boots with: developer | reviewer | design.
AGENT_ROLE=developer

# Claude Code auth via your Claude Pro/Max subscription.
# Generate on the host with:  claude setup-token
# Paste the resulting sk-ant-oat... value here. Do NOT also set ANTHROPIC_API_KEY
# (it would take precedence and switch to metered API billing).
CLAUDE_CODE_OAUTH_TOKEN=

# Toolset bootstrap on container start: auto | skip.
BOOTSTRAP=auto
